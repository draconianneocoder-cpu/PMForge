# Build artifacts. The Wails build scaffold is tracked: build/appicon.png
# (master app icon, wails derives the platform .icns/.ico from it) and the
# build/darwin Info plists. Everything else under build/ is generated output
# (compiled .app/binaries, packages, generated icons).
/build/*
!/build/appicon.png
!/build/darwin/
/build/darwin/*
!/build/darwin/Info.plist
!/build/darwin/Info.dev.plist
!/build/linux/
/build/linux/*
!/build/linux/pmforge.desktop
!/build/linux/nfpm.yaml
!/build/linux/appimage-tools.sha256
/bin/
*.exe
*.dll
*.so
*.dylib
/pmforge
/pmforge-*
/PMForge/
!pmforge-icon-*.svg
!pmforge-logo-*.svg

# Wails generated bindings
/frontend/wailsjs/

# Stale pre-relocation embed copy (main package moved from cmd/pmforge to root)
/cmd/

# Node
/frontend/node_modules/
/frontend/dist/
/frontend/.svelte-kit/
frontend/package.json.md5

# Local validation scratch space
/.tmp/

# Local agent handoff and execution plans. These can contain machine-specific
# paths, dirty-worktree notes, and private planning context.
/session-notes.md
/docs/superpowers/plans/

# Superseded root agent-instruction duplicates; keep public guidance in AGENTS.md.
/CLAUDE.md
/GO_CODER_AGENTS.md

# Go
*.test
*.out
coverage.txt

# Project data (don't commit user data)
*.pmforge
*.pmforge-wal
*.pmforge-shm
*.pmba
*.bak
temp_snapshot.db

# Downloaded/generated binary inputs
/internal/fonts/assets/*.ttf
/PMForge Icon Image *.png
/PMForge Logo Image *.png

# Certificates (NEVER commit private keys)
*.p12
*.pfx
*.key
*.pem
!LICENSES/*.txt
/LICENSES/OFL-1.1.txt

# Agent memory (local-only; not for public consumption)
/.agent_memory/

# Claude Code local permission allowlist (machine-specific, not public)
/.claude/settings.local.json

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
