module pmforge

go 1.26.3

require (

	// V2.x — Foundation Slice additions:
	// gorules/zen-go drives the Launchpad's template-seeding rules
	// as JDM (JSON Decision Model) data rather than Go switch-case.
	// New industry/methodology combinations can ship as new rule
	// rows without recompiling. Used in internal/templates.
	github.com/gorules/zen-go v0.43.0
	github.com/jung-kurt/gofpdf v1.16.2
	github.com/mattn/go-sqlite3 v1.14.22

	// rickar/cal/v2 supplies maintained holiday datasets for ~40
	// countries. Used by internal/calendar and internal/export/ical.go
	// to mark holidays on the Timeline view and to skip non-business
	// days when emitting iCal events.
	github.com/rickar/cal/v2 v2.1.16
	github.com/wailsapp/wails/v2 v2.9.2
	github.com/xuri/excelize/v2 v2.8.1
	golang.org/x/crypto v0.31.0
)
