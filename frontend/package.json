{
  "name": "pmforge-frontend",
  "version": "1.1.0",
  "description": "PMForge Svelte 5 frontend.",
  "license": "GPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
