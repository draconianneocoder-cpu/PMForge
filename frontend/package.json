    "@testing-library/svelte": "^5.4.2",
    "@tsconfig/svelte": "^5.0.4",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.10.0",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.13.0",
    "eslint-plugin-svelte": "^2.46.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.20",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "tailwindcss": "^3.4.14",
    "tslib": "^2.8.0",
    "typescript": "^5.6.3",
